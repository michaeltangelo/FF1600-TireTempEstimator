<UserControl x:Class="FF1600TireEstimator.Plugin.SettingsControlDemo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="900">
            <TextBlock FontSize="26" FontWeight="SemiBold" Text="FF1600 Tire Estimator" />
            <TextBlock Margin="0,6,0,22" Opacity="0.72"
                       Text="Durable telemetry capture for iRacing's Ray Formula 1600."
                       TextWrapping="Wrap" />

            <Border Padding="20" BorderBrush="#3F808080" BorderThickness="1" CornerRadius="5">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Telemetry capture" />
                    <TextBlock Margin="0,5,0,16" Opacity="0.72"
                               Text="Capture arms outside an eligible session and records automatically when a live FF1600 session is available."
                               TextWrapping="Wrap" />
                    <WrapPanel Margin="0,0,0,18">
                        <styles:SHButtonPrimary Margin="0,0,10,0" Padding="22,8"
                                                Click="StartCapture_Click">Start capture</styles:SHButtonPrimary>
                        <styles:SHButtonSecondary Margin="0,0,10,0" Padding="22,8"
                                                  Click="StopCapture_Click">Stop capture</styles:SHButtonSecondary>
                        <styles:SHButtonSecondary Padding="22,8"
                                                  Click="ToggleCapture_Click">Toggle</styles:SHButtonSecondary>
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" FontWeight="SemiBold" Text="State" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="StateValue" Text="Stopped" />
                        <TextBlock Grid.Row="1" Margin="0,8,0,0" FontWeight="SemiBold" Text="Requested" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" x:Name="RequestedValue" Text="False" />
                        <TextBlock Grid.Row="2" Margin="0,8,0,0" FontWeight="SemiBold" Text="Run ID" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" x:Name="RunIdValue" Text="&lt;none&gt;" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="3" Margin="0,8,0,0" FontWeight="SemiBold" Text="Accepted records" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" x:Name="AcceptedValue" Text="0" />
                        <TextBlock Grid.Row="4" Margin="0,8,0,0" FontWeight="SemiBold" Text="Rejected records" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" x:Name="RejectedValue" Text="0" />
                        <TextBlock Grid.Row="5" Margin="0,8,0,0" FontWeight="SemiBold" Text="Fault" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" x:Name="FaultValue" Text="&lt;none&gt;" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,18,0,0" Padding="20" BorderBrush="#3F808080" BorderThickness="1" CornerRadius="5">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Evidence location" />
                    <TextBox Margin="0,10,0,0" x:Name="EvidencePathValue"
                             IsReadOnly="True" TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0" Opacity="0.72"
                               Text="Evidence is append-only JSON Lines. Existing runs are never overwritten."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Margin="0,18,0,0" Padding="20" BorderBrush="#3F808080" BorderThickness="1" CornerRadius="5">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Diagnostics" />
                    <TextBox Margin="0,10,0,0" x:Name="DiagnosticsValue"
                             MinHeight="180" MaxHeight="360" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
